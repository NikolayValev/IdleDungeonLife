{
  "compilerOptions": {
    "target": "ES2023",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2023", "DOM"],
    "skipLibCheck": true,
    "rootDir": ".",
    "outDir": ".test-build",
    "declaration": false,
    "sourceMap": false,
    "noEmit": false,
    "strict": true,
    "esModuleInterop": true
  },
  "include": [
    "src/core/**/*.ts",
    "src/sim/**/*.ts",
    "src/content/**/*.ts",
    "src/ui/avatar/**/*.ts",
    "src/step.ts"
  ]
}
